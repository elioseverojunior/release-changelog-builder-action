{
  "name": "release-changelog-builder-action",
  "version": "0.0.1",
  "description": "",
  "type": "module",
  "main": "dist/index.js",
  "output": "dist",
  "engines": {
    "node": ">=24.0.0,<25.0.0",
    "bun": "1.3.14",
    "typescript": ">=5.0.0,<7.0.0"
  },
  "dependencies": {},
  "devDependencies": {
    "@commitlint/cli": ">=19.8.1,<20.0.0",
    "@commitlint/config-conventional": ">=19.8.1,<20.0.0",
    "@eslint/eslintrc": "^3.3.6",
    "@eslint/js": ">=10.0.1,<11.0.0",
    "@github/markdownlint-github": ">=0.8.3,<1.0.0",
    "@types/bun": ">=1.3.14,<2.0.0",
    "@types/js-yaml": ">=4.0.9,<5.0.0",
    "@types/node": ">=24.0.0,<25.0.0",
    "@typescript-eslint/eslint-plugin": ">=8.64.0,<9.0.0",
    "@typescript-eslint/parser": ">=8.64.0,<9.0.0",
    "action-docs": ">=2.5.1,<3.0.0",
    "bun-types": ">=1.3.14,<2.0.0",
    "eslint": ">=10.7.0,<11.0.0",
    "eslint-config-prettier": ">=10.1.8,<11.0.0",
    "eslint-import-resolver-typescript": ">=4.4.5,<5.0.0",
    "eslint-plugin-github": "^6.1.1",
    "eslint-plugin-import-x": ">=4.17.1,<5.0.0",
    "eslint-plugin-prettier": ">=5.5.6,<6.0.0",
    "globals": ">=17.7.0,<18.0.0",
    "prettier": ">=3.9.5,<4.0.0",
    "prettier-plugin-organize-imports": ">=4.3.0,<5.0.0",
    "ts-node": ">=10.9.2,<11.0.0",
    "typescript": ">=5.0.0,<7.0.0"
  },
  "private": false,
  "overrides": {},
  "peerDependencies": {
    "typescript": ">=6.0.0,<7.0.0"
  },
  "lint-staged": {
    "*.{ts}": [
      "eslint --fix --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,yml,yaml,md}": [
      "prettier --write"
    ]
  },
  "trustedDependencies": [
    "unrs-resolver"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist/action --target node --format esm --external @actions/core --outfile index.js",
    "deps": "bunx --bun npm-check-updates -u --target minor && bun install",
    "deps:check": "bunx --bun npm-check-updates --target minor",
    "deps:latest": "bunx --bun npm-check-updates -u --target latest && bun install",
    "eslint:lint": "eslint --max-warnings 0 .",
    "eslint:lint:fix": "eslint --fix --max-warnings 0 .",
    "fix:all": "bun run eslint:lint:fix && bun run prettier:format:fix",
    "lint": "bun run --filter '*' lint",
    "prettier:format": "prettier --check .",
    "prettier:format:fix": "prettier --write .",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsc -p tsconfig.base.json --noEmit",
    "typecheck:watch": "tsc -p tsconfig.base.json --noEmit --watch"
  }
}
